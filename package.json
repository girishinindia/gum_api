{
  "name": "growupmore-api",
  "version": "0.1.0",
  "private": true,
  "description": "GrowUpMore Enterprise E-Learning Platform — REST API. Strict UDF-only data access (no naked SQL).",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc -p tsconfig.scripts.json",
    "verify": "tsx scripts/verify-config.ts",
    "verify:failfast": "npm run build && tsx scripts/verify-failfast.ts",
    "verify:db": "tsx scripts/verify-db.ts",
    "verify:redis": "tsx scripts/verify-redis.ts",
    "verify:validation": "tsx scripts/verify-validation.ts",
    "verify:middleware": "tsx scripts/verify-middleware.ts",
    "verify:auth": "tsx scripts/verify-auth.ts",
    "verify:resources": "tsx scripts/verify-resources.ts",
    "verify:junctions": "tsx scripts/verify-junctions.ts",
    "verify:users": "tsx scripts/verify-users.ts",
    "verify:auth-flows": "tsx scripts/verify-auth-flows.ts",
    "verify:master-data": "tsx scripts/verify-master-data.ts",
    "verify:patch-unified": "tsx scripts/verify-patch-unified.ts",
    "verify:branch-management": "tsx scripts/verify-branch-management.ts",
    "verify:user-profiles": "tsx scripts/verify-phase-04.ts",
    "verify:user-education": "tsx scripts/verify-phase-04-education.ts",
    "verify:user-experience": "tsx scripts/verify-phase-04-experience.ts",
    "verify:user-social-medias": "tsx scripts/verify-phase-04-user-social-medias.ts",
    "verify:user-skills": "tsx scripts/verify-phase-04-user-skills.ts",
    "verify:user-languages": "tsx scripts/verify-phase-04-user-languages.ts",
    "verify:user-documents": "tsx scripts/verify-phase-04-user-documents.ts",
    "verify:user-projects": "tsx scripts/verify-phase-04-user-projects.ts",
    "verify:all": "npm run verify && npm run verify:db && npm run verify:redis && npm run verify:validation && npm run verify:middleware && npm run verify:auth && npm run verify:auth-flows && npm run verify:resources && npm run verify:junctions && npm run verify:users && npm run verify:master-data && npm run verify:patch-unified && npm run verify:branch-management && npm run verify:user-profiles && npm run verify:user-education && npm run verify:user-experience && npm run verify:user-social-medias && npm run verify:user-skills && npm run verify:user-languages && npm run verify:user-documents && npm run verify:user-projects",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mime-types": "^3.0.2",
    "ms": "^2.1.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mime-types": "^3.0.1",
    "@types/ms": "^2.1.0",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
