{
  "info": {
    "name": "Grow Up More \u2014 Phase 5: Employee Management",
    "description": "Phase 5 endpoints: Employee Profiles.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [],
  "item": [
    {
      "name": "Employee Profiles",
      "description": "Employee profile management",
      "item": [
        {
          "name": "GET / (list employee profiles)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employee-profiles?limit=10&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee-profiles"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "List all employee profiles (admin+)"
          }
        },
        {
          "name": "GET /me (get own employee profile)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employee-profiles/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee-profiles",
                "me"
              ]
            },
            "description": "Get your own employee profile"
          }
        },
        {
          "name": "PATCH /me (update own employee profile)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employee-profiles/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee-profiles",
                "me"
              ]
            },
            "description": "Update your own employee profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"departmentId\": 2,\n  \"designationId\": 5,\n  \"joinDate\": \"2020-06-01\",\n  \"isActive\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "POST / (create employee profile)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employee-profiles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee-profiles"
              ]
            },
            "description": "Create employee profile for a user (admin+)",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 6,\n  \"departmentId\": 1,\n  \"designationId\": 3,\n  \"joinDate\": \"2023-01-15\",\n  \"isActive\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('employeeProfileId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /:id (get employee profile)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employee-profiles/{{employeeProfileId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee-profiles",
                "{{employeeProfileId}}"
              ]
            },
            "description": "Get employee profile by ID"
          }
        },
        {
          "name": "PATCH /:id (update employee profile)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employee-profiles/{{employeeProfileId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee-profiles",
                "{{employeeProfileId}}"
              ]
            },
            "description": "Update employee profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"designationId\": 4\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "DELETE /:id (soft-delete employee profile)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employee-profiles/{{employeeProfileId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee-profiles",
                "{{employeeProfileId}}"
              ]
            },
            "description": "Soft-delete employee profile"
          }
        },
        {
          "name": "POST /:id/restore (restore employee profile)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/employee-profiles/{{employeeProfileId}}/restore",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee-profiles",
                "{{employeeProfileId}}",
                "restore"
              ]
            },
            "description": "Restore soft-deleted employee profile (admin+)"
          }
        }
      ],
      "_postman_isSubFolder": true
    }
  ],
  "_postman_id": "210411f6-ad75-4986-a77e-c1e9a2ac1204"
}