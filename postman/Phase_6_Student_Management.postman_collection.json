                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/student-profiles?limit=10&offset=0",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "student-profiles"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "List all student profiles (admin+)"
