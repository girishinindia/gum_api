        {
          "name": "POST / (create student profile - JSON)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/student-profiles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "student-profiles"
              ]
            },
            "description": "Create student profile for a user (admin+)",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 7,\n  \"enrollmentDate\": \"2023-09-01\",\n  \"specialization\": \"Full Stack Development\",\n  \"cgpa\": 3.75\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "  pm.environment.set('studentProfileId', json.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
